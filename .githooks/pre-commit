#!/usr/bin/env bash
set -euo pipefail

# Rebuild dist/ when source-affecting files are staged, then stage the result.
# Stashes unstaged + untracked changes first so the build reflects ONLY what's
# being committed (correct behaviour under partial staging like `git commit -p`).
# The companion post-commit hook restores the stash after git seals the commit.

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

if ! grep -qE '^(src/|scripts/|tsup\.config\.ts|tsconfig\.json|package\.json|yarn\.lock)' <<<"$STAGED"; then
  exit 0
fi

GIT_DIR=$(git rev-parse --git-dir)
MARKER="$GIT_DIR/precommit-stash-pending"

# Recover from a previous aborted commit: if a marker is stale, pop now before
# we stash anything new (otherwise post-commit would pop the wrong entry).
if [ -f "$MARKER" ]; then
  echo "[pre-commit] WARNING: stale stash marker — recovering by popping previous stash" >&2
  git stash pop --quiet 2>/dev/null || true
  rm -f "$MARKER"
fi

NEEDS_STASH=0
if ! git diff --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  NEEDS_STASH=1
fi

# On failure only: pop the stash so the user's working tree isn't left empty.
# On success: leave the stash for post-commit to restore.
rollback_on_failure() {
  local ec=$?
  if [ "$ec" -ne 0 ] && [ "$NEEDS_STASH" -eq 1 ]; then
    git stash pop --quiet 2>/dev/null || \
      echo "[pre-commit] WARNING: rollback pop failed — unstaged work is in stash@{0}" >&2
    rm -f "$MARKER"
  fi
  exit "$ec"
}
trap rollback_on_failure EXIT

if [ "$NEEDS_STASH" -eq 1 ]; then
  echo "[pre-commit] stashing unstaged changes" >&2
  git stash push --keep-index --include-untracked --quiet --message "pre-commit-build"
  : > "$MARKER"
fi

echo "[pre-commit] source files staged — running yarn build" >&2
yarn build >&2

git add dist/
