{
  "name": "@claudikins/tool-executor",
  "version": "1.1.3",
  "description": "MCP server that wraps multiple MCP servers into a single context-efficient interface - part of the Claudikins framework",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claudikins": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elb-pr/claudikins-tool-executor.git"
  },
  "keywords": [
    "mcp",
    "claude",
    "anthropic",
    "claudikins",
    "tool-executor",
    "context-efficient",
    "model-context-protocol"
  ],
  "author": "Ethan Lee",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/elb-pr/claudikins-tool-executor/issues"
  },
  "homepage": "https://github.com/elb-pr/claudikins-tool-executor#readme",
  "files": [
    "dist",
    "registry",
    "tool-executor.config.example.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "tchk": "tsc --noEmit",
    "start": "node dist/index.js",
    "extract": "tsx scripts/extract-schemas.ts",
    "test": "vitest",
    "test:unit": "vitest run src",
    "test:unit:mutation": "stryker run",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "glob": "^10.3.0",
    "js-yaml": "^4.1.0",
    "wink-bm25-text-search": "^3.1.2",
    "wink-nlp-utils": "^2.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "yarn@4.14.1"
}
