{
  "name": "@claudikins/tool-executor",
  "version": "1.1.0",
  "description": "MCP server that wraps multiple MCP servers into a single context-efficient interface - part of the Claudikins framework",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claudikins": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elb-pr/claudikins-tool-executor.git"
  },
  "keywords": [
    "mcp",
    "claude",
    "anthropic",
    "claudikins",
    "tool-executor",
    "context-efficient",
    "model-context-protocol"
  ],
  "author": "Ethan Lee",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/elb-pr/claudikins-tool-executor/issues"
  },
  "homepage": "https://github.com/elb-pr/claudikins-tool-executor#readme",
  "files": [
    "dist",
    "registry",
    "tool-executor.config.example.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "extract": "tsx scripts/extract-schemas.ts",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "glob": "^10.3.0",
    "js-yaml": "^4.1.0",
    "wink-bm25-text-search": "^3.1.2",
    "wink-nlp-utils": "^2.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
